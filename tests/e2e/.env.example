# PhaseBinder end-to-end tests — environment
#
# Copy this file to "tests/e2e/.env" (git-ignored) and fill in the values.
# These are read by playwright.config.ts before the suite runs.

# --- Test account (required) ---
# A real Firebase user in the "ammonssoftware" project with the GC role.
# Create one via the app's sign-up screen or the Firebase Auth console.
E2E_GC_EMAIL=
E2E_GC_PASSWORD=

# --- Optional overrides ---
# Where the app is served. Defaults to http://localhost:3000 (Playwright will
# start `npm run dev` for you unless a server is already running).
# For deployed smoke testing, set this to https://phasebinder.com
# E2E_BASE_URL=http://localhost:3000
# E2E_PORT=3000

# The seeded project specs fall back to. Defaults to the demo project created
# by `npm run seed`.
# E2E_PROJECT_NAME=Maple Street Apartments (Demo)
