rules_version = '2';

// Firestore security rules for PhaseBinder.
//
// This ruleset keeps gc_site_super access fully intact while reducing broad
// write permissions for non-manager roles.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserRole() {
      return signedIn() && exists(currentUserDocPath())
        ? get(currentUserDocPath()).data.role
        : null;
    }

    function canManage() {
      return signedIn() &&
        currentUserRole() in ['admin', 'gc_site_super', 'internal_team'];
    }

    // User profile documents are keyed by auth uid.
    // Managers can read all profiles; users can always read/update their own.
    match /users/{userId} {
      allow read: if canManage() || (signedIn() && request.auth.uid == userId);
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Core workflow data is manager-managed. This preserves full gc_site_super
    // capabilities and limits mutation for non-manager roles.
    match /projects/{projectId} {
      allow read, write: if canManage();
    }

    match /contractors/{contractorId} {
      allow read, write: if canManage();
    }

    match /trades/{tradeId} {
      allow read, write: if canManage();
    }

    match /tradePhases/{phaseId} {
      allow read, write: if canManage();
    }

    // Append-only audit trail.
    match /activityLogs/{logId} {
      allow read, create: if canManage();
      allow update, delete: if false;
    }

    match /materialOrders/{orderId} {
      allow read, write: if canManage();
    }

    match /punchItems/{punchItemId} {
      allow read, write: if canManage();
    }

    match /completionRecords/{recordId} {
      allow read, create, update: if canManage();
      allow delete: if false;
    }

    match /inspections/{inspectionId} {
      allow read, create: if canManage();
      allow update, delete: if false;
    }

    // Managers can send and update notifications. Recipients may read and mark
    // their own records as read.
    match /notifications/{notificationId} {
      allow read: if canManage() ||
        (signedIn() && resource.data.recipient_id == request.auth.uid);
      allow create: if canManage();
      allow update: if canManage() ||
        (signedIn() &&
          resource.data.recipient_id == request.auth.uid &&
          request.resource.data.recipient_id == resource.data.recipient_id &&
          request.resource.data.type == resource.data.type &&
          request.resource.data.related_entity_type == resource.data.related_entity_type &&
          request.resource.data.related_entity_id == resource.data.related_entity_id);
      allow delete: if false;
    }

    match /documents/{documentId} {
      allow read, write: if canManage();
    }

    // Tokenized links: direct doc get stays public-by-token; management is
    // manager-only.
    match /contractorActionLinks/{token} {
      allow get: if true;
      allow list, create, update: if canManage();
      allow delete: if false;
    }
  }
}
