rules_version = '2';

// Firestore security rules for PhaseBinder.
//
// Multi-tenant isolation: each signed-in account can only read/write documents
// it owns.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function ownsResource(field) {
      return signedIn() && resource.data[field] == request.auth.uid;
    }

    function createsOwned(field) {
      return signedIn() && request.resource.data[field] == request.auth.uid;
    }

    function projectPath(projectId) {
      return /databases/$(database)/documents/projects/$(projectId);
    }

    function tradePath(tradeId) {
      return /databases/$(database)/documents/trades/$(tradeId);
    }

    function phasePath(phaseId) {
      return /databases/$(database)/documents/tradePhases/$(phaseId);
    }

    function ownsProject(projectId) {
      return signedIn() &&
        projectId != null &&
        exists(projectPath(projectId)) &&
        get(projectPath(projectId)).data.created_by == request.auth.uid;
    }

    function ownsTrade(tradeId) {
      return signedIn() &&
        tradeId != null &&
        exists(tradePath(tradeId)) &&
        get(tradePath(tradeId)).data.created_by == request.auth.uid;
    }

    function ownsPhase(phaseId) {
      return signedIn() &&
        phaseId != null &&
        exists(phasePath(phaseId)) &&
        get(phasePath(phaseId)).data.created_by == request.auth.uid;
    }

    // User profile documents are keyed by auth uid.
    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Core workflow data is owner-scoped.
    match /projects/{projectId} {
      allow read, update, delete: if ownsResource('created_by');
      allow create: if createsOwned('created_by');
    }

    match /contractors/{contractorId} {
      allow read, update, delete: if ownsResource('created_by');
      allow create: if createsOwned('created_by');
    }

    match /trades/{tradeId} {
      allow read, update, delete: if ownsResource('created_by');
      allow create: if createsOwned('created_by') &&
        ownsProject(request.resource.data.project_id);
    }

    match /tradePhases/{phaseId} {
      allow read, update, delete: if ownsResource('created_by');
      allow create: if createsOwned('created_by') &&
        ownsProject(request.resource.data.project_id) &&
        ownsTrade(request.resource.data.trade_id);
    }

    // Append-only audit trail.
    match /activityLogs/{logId} {
      allow read: if ownsResource('user_id');
      allow create: if createsOwned('user_id');
      allow update, delete: if false;
    }

    match /materialOrders/{orderId} {
      allow read, update, delete: if ownsResource('created_by');
      allow create: if createsOwned('created_by') &&
        ownsProject(request.resource.data.project_id) &&
        (
          request.resource.data.trade_phase_id == null ||
          ownsPhase(request.resource.data.trade_phase_id)
        );
    }

    match /punchItems/{punchItemId} {
      allow read, update, delete: if ownsResource('created_by');
      allow create: if createsOwned('created_by') &&
        ownsProject(request.resource.data.project_id) &&
        ownsPhase(request.resource.data.trade_phase_id);
    }

    match /completionRecords/{recordId} {
      allow read, update: if ownsResource('submitted_by');
      allow create: if createsOwned('submitted_by') &&
        ownsProject(request.resource.data.project_id) &&
        ownsPhase(request.resource.data.trade_phase_id);
      allow delete: if false;
    }

    match /inspections/{inspectionId} {
      allow read: if ownsResource('inspector_id');
      allow create: if createsOwned('inspector_id') &&
        ownsProject(request.resource.data.project_id) &&
        ownsPhase(request.resource.data.trade_phase_id);
      allow update, delete: if false;
    }

    // Owner-scoped notifications.
    match /notifications/{notificationId} {
      allow read, update: if ownsResource('user_id');
      allow create: if createsOwned('user_id');
      allow delete: if false;
    }

    match /documents/{documentId} {
      allow read, update, delete: if ownsResource('uploaded_by');
      allow create: if createsOwned('uploaded_by') &&
        ownsProject(request.resource.data.project_id);
    }

    // Tokenized links: direct doc get stays public-by-token; management is
    // owner-only.
    match /contractorActionLinks/{token} {
      allow get: if true;
      allow list, update: if ownsResource('created_by');
      allow create: if createsOwned('created_by') &&
        ownsProject(request.resource.data.project_id);
      allow delete: if false;
    }
  }
}
