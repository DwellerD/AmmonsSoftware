rules_version = '2';

// Firestore security rules for TradeFlow.
//
// This is an MVP ruleset: any signed-in user can read and write the shared
// project data. Tighten these before a production launch (e.g. per-project
// membership, role checks, field validation).
service cloud.firestore {
  match /databases/{database}/documents {

    // True when the request is made by an authenticated user.
    function signedIn() {
      return request.auth != null;
    }

    // User profile documents are keyed by the auth uid.
    // Anyone signed in can read profiles (to show names/roles); a user may
    // only create or modify their own profile document.
    match /users/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    // Core shared collections: readable and writable by any signed-in user.
    match /projects/{projectId} {
      allow read, write: if signedIn();
    }

    match /contractors/{contractorId} {
      allow read, write: if signedIn();
    }

    match /trades/{tradeId} {
      allow read, write: if signedIn();
    }

    match /tradePhases/{phaseId} {
      allow read, write: if signedIn();
    }

    // Activity logs are an append-only audit trail: signed-in users can read
    // and create entries, but not edit or delete existing ones.
    match /activityLogs/{logId} {
      allow read, create: if signedIn();
      allow update, delete: if false;
    }

    // Sprint 2 collections. Material orders and punch items change over their
    // lifecycle, so they allow full read/write. Completion proof and
    // inspections are records of what happened, so they are read + create only
    // (no edits or deletes).
    match /materialOrders/{orderId} {
      allow read, write: if signedIn();
    }

    match /punchItems/{punchItemId} {
      allow read, write: if signedIn();
    }

    // Completion proof: signed-in users can read, create, and update (the GC
    // updates the review status on approval/rejection). Deletes are blocked so
    // the submission history stays intact.
    match /completionRecords/{recordId} {
      allow read, create, update: if signedIn();
      allow delete: if false;
    }

    match /inspections/{inspectionId} {
      allow read, create: if signedIn();
      allow update, delete: if false;
    }

    // Notification records (in-app only for Sprint 2). Signed-in users can read
    // and create them, and update to flip the read status. Deletes are blocked.
    match /notifications/{notificationId} {
      allow read, create, update: if signedIn();
      allow delete: if false;
    }

    // Project documents (Sprint 3 Document Vault). Signed-in users can read,
    // create, update (rename, re-tag, pin/unpin), and delete their files.
    match /documents/{documentId} {
      allow read, write: if signedIn();
    }
  }
}
